# Kafka Configuration
KAFKA_BROKER=localhost:9092

# Stock Symbols (must match order with COMPANY_NAMES)
STOCKS=AAPL,GOOGL,MSFT
COMPANY_NAMES=Apple,Google,Microsoft

# Finnhub API
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI
NEWS_API_KEY=your_newsapi_key_here

# Reddit API Credentials
# Get these from https://ssl.reddit.com/prefs/apps/ , 
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=pathway-news-agent:v1.0 (by u/YOUR_USERNAME)

# Reddit Configuration
REDDIT_SUBREDDITS=wallstreetbets,stocks,investing,StockMarket
REDDIT_COMMENT_LIMIT=2
REDDIT_SEARCH_LIMIT=5

# Fetch Intervals (in seconds)
MARKET_DATA_INTERVAL=300
NEWS_DATA_INTERVAL=300
SENTIMENT_DATA_INTERVAL=300