# Kafka Configuration
KAFKA_BROKER=localhost:9092

# Stock Symbols (must match order with COMPANY_NAMES)
STOCKS=AAPL,GOOGL,MSFT
COMPANY_NAMES=Apple,Google,Microsoft

# Finnhub API
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI
NEWS_API_KEY=your_newsapi_key_here

# Fallback APIs
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FMP_API_KEY=your_fmp_key
COINCAP_API_KEY=your_coincap_key

# Reddit API Credentials
# Get these from https://ssl.reddit.com/prefs/apps/ , 
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=pathway-news-agent:v1.0 (by u/YOUR_USERNAME)

# Reddit Configuration
REDDIT_SUBREDDITS=wallstreetbets,stocks,investing,StockMarket
REDDIT_COMMENT_LIMIT=2
REDDIT_SEARCH_LIMIT=5

# Twitter/X API Credentials
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# Fetch Intervals (in seconds)
MARKET_DATA_INTERVAL=60
TECHNICAL_INDICATORS_INTERVAL=300
FUNDAMENTAL_DATA_INTERVAL=3600
NEWS_DATA_INTERVAL=30
SOCIAL_SENTIMENT_INTERVAL=600
SENTIMENT_DATA_INTERVAL=1200

# OpenRouter API (for AI-powered summaries)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Fundamental Analysis Configuration
GENERATE_REPORTS=true
ENABLE_WEB_SCRAPING=true
ENABLE_AI_SUMMARY=true
MAX_ARTICLES_PER_STOCK=8

