# Kafka Configuration
KAFKA_BROKER=localhost:9092

# Stock Symbols
STOCKS=AAPL

# Finnhub API
FINNHUB_API_KEY=your-finnhub-api-key-here

# NewsAPI
NEWS_API_KEY=your-news-api-key-here

# Fallback APIs
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key-here
FMP_API_KEY=your-fmp-api-key-here
COINCAP_API_KEY=your-coincap-api-key-here

REDDIT_CLIENT_IDS=list-of-your-reddit-client-ids-here
REDDIT_CLIENT_SECRETS=list-of-your-reddit-client-secrets-here

# Twitter API Configuration (TwitterAPI.io)
TWITTER_API_KEY=your-twitter-api-key-here
TWITTER_WEBHOOK_URL=https://test-something-wp.free.beeceptor.com
TWITTER_CHECK_INTERVAL=60  # Check webhook every 60 seconds (1 minute)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5001

# Sentiment Logging
ENABLE_SENTIMENT_LOGGING=true

# Reddit Configuration
REDDIT_SUBREDDITS=wallstreetbets,stocks,investing,StockMarket
REDDIT_COMMENT_LIMIT=10

# Fetch Intervals (in seconds)
MARKET_DATA_INTERVAL=60
TECHNICAL_INDICATORS_INTERVAL=300
FUNDAMENTAL_DATA_INTERVAL=36000
NEWS_DATA_INTERVAL=30
SOCIAL_SENTIMENT_INTERVAL=600
SENTIMENT_DATA_INTERVAL=60  # Fetch from Twitter webhook every 60 seconds (1 minute)

# Fundamental Analysis Configuration
GENERATE_REPORTS=true
ENABLE_WEB_SCRAPING=true
ENABLE_AI_SUMMARY=true
MAX_ARTICLES_PER_STOCK=10
SCRAPER_TIMEOUT=10
 
# Serpex API (Google Search)
SERPEX_API_KEY=your-serpex-api-key-here

# OpenAI API (for AI-enhanced reports via OpenRouter)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter Configuration
OPENROUTER_API_KEY=your-openrouter-api-key-here