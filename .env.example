# ============================================
# UNIFIED ENVIRONMENT CONFIGURATION
# ============================================
# All docker-compose files use: env_file: - ../.env
# ============================================

# ============================================
# STOCKS CONFIGURATION
# ============================================
STOCKS=AAPL,GOOGL,MSFT,TSLA,NVDA
COMPANY_NAMES=Apple,Google,Microsoft,Tesla,Nvidia
STOCK_COMPANY_MAP={"AAPL":"Apple Inc.","GOOGL":"Alphabet Inc.","MSFT":"Microsoft Corporation","TSLA":"Tesla Inc.","NVDA":"NVIDIA Corporation"}

# ============================================
# CANDLE PRODUCER CONFIGURATION
# ============================================
# Comma-separated intervals for backtesting candles (1m, 5m, 15m, 1h, 1d)
INTERVALS=1h,1d
# Seconds between candle fetch cycles
CANDLE_CYCLE_INTERVAL=60

RAG_DOCSTORE_ENABLED=true
# ============================================
# LLM / AI CONFIGURATION
# ============================================
OPENAI_API_KEY=key
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_AGENT=openai/gpt-4o-mini
OPENAI_MODEL_RISK=google/gemini-2.0-flash-lite-001
OPENAI_EMBED_MODEL=text-embedding-3-small

# ============================================
# DATA SOURCES - API KEYS
# ============================================
FMP_API_KEY=key
FINNHUB_API_KEY=key
NEWS_API_KEY=key
SEC_API=key
CRUNCHBASE_API_KEY=key
SERPAPI_API_KEY=key
SERPEX_API_KEY=key

# ============================================
# REDDIT CONFIGURATION
# ============================================
REDDIT_CLIENT_ID=key
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
REDDIT_SUBREDDITS=wallstreetbets,stocks,investing
REDDIT_COMMENT_LIMIT=2
REDDIT_SEARCH_LIMIT=5

# ============================================
# TWITTER CONFIGURATION
# ============================================
TWITTER_API_KEY=
TWITTER_WEBHOOK_URL=https://webhook.animexdev.com
TWITTER_CHECK_INTERVAL=120
WEBHOOK_RECEIVER_URL=http://host.docker.internal:5001
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5001

# ============================================
# VISION / DOCUMENT PARSING
# ============================================
VISION_AGENT_API_KEY=key
LANDINGAI_API_KEY=key
UNSTRUCTURED_API_KEY=key

# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_BROKER=kafka:29092
MARKET_TOPIC=market-data
NEWS_TOPIC=news-data
SENTIMENT_TOPIC=sentiment-data
CANDLE_KAFKA_TOPIC=candles

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_REPORT_TTL=
REDIS_IMAGE_TTL=3600
REDIS_NEWS_CLUSTER_TTL=3600
REDIS_SENTIMENT_TTL=3600
REDIS_BACKTESTING_TTL=

# ============================================
# POSTGRESQL CONFIGURATION
# ============================================
DATABASE_URL=postgresql://user:password@postgres:5432/reports

# ============================================
# PATHWAY CONFIGURATION
# ============================================
PATHWAY_LICENSE_KEY=key
PATHWAY_SNAPSHOT_INTERVAL_MS=60000

# ============================================
# CLUSTERING CONFIGURATION
# ============================================
SIMILARITY_THRESHOLD=0.75
MERGE_THRESHOLD=0.85
MAX_POSTS_PER_CLUSTER=50
CLUSTER_MAX_AGE_HOURS=48

# ============================================
# ALERTS CONFIGURATION
# ============================================
SENTIMENT_ALERT_ENABLED=true
SENTIMENT_ALERT_MIN=-0.0001
SENTIMENT_ALERT_MAX=0.0001
SENTIMENT_ALERT_COOLDOWN=600
NEWS_ALERT_ENABLED=true
NEWS_ALERT_COOLDOWN=600
NEWS_ALERT_MIN_CLUSTERS=3
BULLBEAR_API_URL=http://unified-api:8000
BULLBEAR_GUARDRAILS_ENABLED=true

# ============================================
# DRIFT DETECTION CONFIGURATION
# ============================================
DRIFT_SPIKE_THRESHOLD=3.0
DRIFT_GRADUAL_THRESHOLD=0.05
DRIFT_VARIANCE_THRESHOLD=1.0
DRIFT_ADWIN_DELTA=0.002
DRIFT_PH_THRESHOLD=50
DRIFT_ALERT_COOLDOWN=10

# ============================================
# MARKET DATA CONFIGURATION
# ============================================
MARKET_LOOKBACK_MINUTES=10
MARKET_HOP_MINUTES=5
MIN_DATA_POINTS=30

# ============================================
# FETCH INTERVALS (seconds)
# ============================================
MARKET_DATA_INTERVAL=45
NEWS_DATA_INTERVAL=1000
SENTIMENT_DATA_INTERVAL=1000
FUNDAMENTAL_REPORT_INTERVAL=5184000
REPORT_GENERATION_INTERVAL=300

# ============================================
# SEC FILINGS CONFIGURATION
# ============================================
SEC_FILINGS_LIMIT=2
SEC_FILINGS_FROM_DATE=
SEC_FILINGS_TO_DATE=

# ============================================
# KNOWLEDGE BASE
# ============================================
KNOWLEDGE_BASE_DIR=../knowledge_base
KNOWLEDGE_BASE_PATH=/app/knowledge_base

# ============================================
# DEMO / BACKTESTING CONFIGURATION
# ============================================
DEMO_TICKER=AAPL
DEMO_INTERVAL=5m
DEMO_SPEEDUP=10.0
STRATEGIES_DIR=/app/strategies

# ============================================
# API URLS (Internal Docker Network)
# ============================================
RAG_API_URL=http://unified-api:8000
REPORTS_API_URL=http://unified-api:8000
BACKTESTING_API_URL=http://unified-api:8000/backtesting

# ============================================
# MCP / ORCHESTRATOR CONFIGURATION
# ============================================
MCP_SERVER_HOST=mcp-server
MCP_SERVER_PORT=9004
MEM0_REDIS_HOST=redis
MEM0_REDIS_PORT=6379
