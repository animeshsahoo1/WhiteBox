# ============================================
# UNIFIED ENVIRONMENT CONFIGURATION
# ============================================
# All docker-compose files use: env_file: - ../.env
# ============================================
# Copy this file to .env and fill in your actual API keys
# ============================================

# ============================================
# STOCKS CONFIGURATION
# ============================================
STOCKS=AAPL
COMPANY_NAMES=Apple
STOCK_COMPANY_MAP={"AAPL":"Apple Inc."}

# ============================================
# LLM / AI CONFIGURATION
# ============================================
# Get your OpenRouter API key from: https://openrouter.ai/
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_AGENT=openai/gpt-4o-mini
OPENAI_MODEL_RISK=google/gemini-2.0-flash-lite-001
OPENAI_EMBED_MODEL=text-embedding-3-small

# ============================================
# DATA SOURCES - API KEYS
# ============================================
# Financial Modeling Prep: https://site.financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_fmp_api_key_here

# Finnhub: https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI: https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# SEC-API: https://sec-api.io/
SEC_API=your_sec_api_key_here

# Crunchbase: https://data.crunchbase.com/docs
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here

# SerpAPI (optional): https://serpapi.com/
SERPAPI_API_KEY=

# Serpex API: https://serpex.dev/
SERPEX_API_KEY=your_serpex_api_key_here

# ============================================
# REDDIT CONFIGURATION
# ============================================
# Get credentials from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=pathway-news-agent:v1.0 (by u/YourUsername)
REDDIT_SUBREDDITS=wallstreetbets,stocks,investing
REDDIT_COMMENT_LIMIT=2
REDDIT_SEARCH_LIMIT=3

# ============================================
# TWITTER CONFIGURATION
# ============================================
# Get from your Twitter/X API provider
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_WEBHOOK_URL=https://your-webhook-url.com
TWITTER_CHECK_INTERVAL=120
WEBHOOK_RECEIVER_URL=http://host.docker.internal:5001
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5001

# ============================================
# VISION / DOCUMENT PARSING
# ============================================
# Landing AI / Vision Agent: https://landing.ai/
VISION_AGENT_API_KEY=your_vision_agent_api_key_here
LANDINGAI_API_KEY=your_landingai_api_key_here

# Unstructured.io: https://unstructured.io/
UNSTRUCTURED_API_KEY=your_unstructured_api_key_here

# Cohere: https://cohere.com/
COHERE_API_KEY=your_cohere_api_key_here

RERANK_ENABLED=false
ADAPTIVE_RAG=false
CONTEXTUAL_ENRICHMENT=false

# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_BROKER=kafka:29092
MARKET_TOPIC=market-data
NEWS_TOPIC=news-data
SENTIMENT_TOPIC=sentiment-data
CANDLE_KAFKA_TOPIC=candles

# ============================================
# REDIS CONFIGURATION
# ============================================
# Upstash Redis URL (or your own Redis instance)
# Get from: https://upstash.com/
REDIS_URL=your_redis_url_here
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_REPORT_TTL=3600
REDIS_IMAGE_TTL=3600
REDIS_NEWS_CLUSTER_TTL=3600
REDIS_SENTIMENT_TTL=3600
REDIS_BACKTESTING_TTL=3600

# ============================================
# POSTGRESQL CONFIGURATION
# ============================================
RAG_DOCSTORE_ENABLED=true

# ============================================
# PATHWAY CONFIGURATION
# ============================================
# Get your license key from: https://pathway.com/
PATHWAY_LICENSE_KEY=your_pathway_license_key_here
PATHWAY_SNAPSHOT_INTERVAL_MS=100000

# ============================================
# CLUSTERING CONFIGURATION
# ============================================
SIMILARITY_THRESHOLD=0.75
MERGE_THRESHOLD=0.85
MAX_POSTS_PER_CLUSTER=50
CLUSTER_MAX_AGE_HOURS=48

# ============================================
# ALERTS CONFIGURATION
# ============================================
SENTIMENT_ALERT_ENABLED=true
SENTIMENT_ALERT_MIN=-0.001
SENTIMENT_ALERT_MAX=0.001
SENTIMENT_ALERT_COOLDOWN=600
NEWS_ALERT_ENABLED=true
NEWS_ALERT_COOLDOWN=600
NEWS_ALERT_MIN_CLUSTERS=3
BULLBEAR_API_URL=http://unified-api:8000
BULLBEAR_GUARDRAILS_ENABLED=true

# ============================================
# DRIFT DETECTION CONFIGURATION
# ============================================
DRIFT_SPIKE_THRESHOLD=3.0
DRIFT_GRADUAL_THRESHOLD=0.05
DRIFT_VARIANCE_THRESHOLD=1.0
DRIFT_ADWIN_DELTA=0.002
DRIFT_PH_THRESHOLD=50
DRIFT_ALERT_COOLDOWN=10

# ============================================
# MARKET DATA CONFIGURATION
# ============================================
MARKET_LOOKBACK_MINUTES=10
MARKET_HOP_MINUTES=5
MIN_DATA_POINTS=30

# ============================================
# FETCH INTERVALS (seconds)
# ============================================
MARKET_DATA_INTERVAL=1000
NEWS_DATA_INTERVAL=1000
SENTIMENT_DATA_INTERVAL=1000
FUNDAMENTAL_REPORT_INTERVAL=5184000
REPORT_GENERATION_INTERVAL=1000

# ============================================
# SEC FILINGS CONFIGURATION
# ============================================
SEC_FILINGS_LIMIT=1
SEC_FILINGS_FROM_DATE=
SEC_FILINGS_TO_DATE=

# ============================================
# KNOWLEDGE BASE
# ============================================
KNOWLEDGE_BASE_DIR=../knowledge_base
# KNOWLEDGE_BASE_PATH is set by Docker only - for local dev, auto-detect from code
KNOWLEDGE_BASE_PATH=/app/knowledge_base

# ============================================
# DEMO / BACKTESTING CONFIGURATION
# ============================================
# USE_DUMMY: When true, pipelines use pw.demo.replay_csv() with demo CSV data
# instead of real Kafka streaming. Useful for testing without live data.
USE_DUMMY=false
DEMO_DATA_DIR=/app/streaming/data/demo_data
DEMO_INPUT_RATE=10.0
DEMO_TICKER=AAPL
DEMO_INTERVAL=5m
DEMO_SPEEDUP=10.0
STRATEGIES_DIR=/app/strategies

# ============================================
# API URLS (Internal Docker Network)
# ============================================
RAG_API_URL=http://unified-api:8000
REPORTS_API_URL=http://unified-api:8000
BACKTESTING_API_URL=http://unified-api:8000/backtesting

# ============================================
# MCP / ORCHESTRATOR CONFIGURATION
# ============================================
MCP_SERVER_HOST=mcp-server
MCP_SERVER_PORT=9004
MEM0_REDIS_HOST=redis
MEM0_REDIS_PORT=6379

# Supabase PostgreSQL URL
# Get from: https://supabase.com/
DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================
# ADDITIONAL CONFIGURATION (Previously Missing)
# ============================================

# ============================================
# DEBUG & LOGGING
# ============================================
DEBUG=false
ENABLE_SENTIMENT_LOGGING=true
VERBOSE_TOOLS=true
LANGCHAIN_TRACING_V2=false

# ============================================
# ADDITIONAL API KEYS
# ============================================
# AlphaVantage: https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=

# Mem0 (optional - for memory management): https://mem0.ai/
MEM0_API_KEY=

# ============================================
# LLM ADDITIONAL CONFIGURATION
# ============================================
BULL_BEAR_MOCK_LLM=false
SUMMARIZE_MODEL=google/gemini-2.0-flash-lite-001
OPENAI_TEMPERATURE_RISK=0.0
OPENAI_MAX_TOKENS_RISK=500
EMBEDDING_MODEL=openai/text-embedding-3-small

# ============================================
# KAFKA ADDITIONAL CONFIGURATION
# ============================================
KAFKA_BATCH_SIZE=10
KAFKA_BATCH_TIMEOUT_MS=1000

# ============================================
# MARKET DATA ADDITIONAL CONFIGURATION
# ============================================
MARKET_HISTORICAL_PERIOD=1d
MARKET_HISTORICAL_INTERVAL=1m
MARKET_MIN_DATA_POINTS=3
INTERVALS=1h,1d
CANDLE_POLL_INTERVAL=60
CANDLE_NO_BACKFILL=false

# ============================================
# SENTIMENT ADDITIONAL CONFIGURATION
# ============================================
SENTIMENT_CLUSTERS_DIR=/app/reports/sentiment/clusters
REDDIT_RATE_LIMIT=55

# ============================================
# NEWS & FUNDAMENTAL DATA
# ============================================
FUNDAMENTAL_DATA_INTERVAL=3600
MAX_ARTICLES_PER_STOCK=10
SCRAPER_TIMEOUT=10

# ============================================
# DRIFT & GUARDRAILS
# ============================================
DRIFT_ALERT_ENABLED=true
GUARDRAILS_ENABLED=true

# ============================================
# ADDITIONAL API URLS
# ============================================
RAG_SERVER_URL=http://localhost:8000

# ============================================
# DEMO & WEBHOOK
# ============================================
DEMO_DATA_DIR=/app/demo_data
WEBHOOK_RECEIVER_PORT=5001

# ============================================
# TESTING/DEVELOPMENT
# ============================================
EXPERIMENT=test
