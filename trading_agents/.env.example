# Trading Agents Configuration

# ============================================
# API Configuration
# ============================================

# Pathway API (for fetching input reports)
PATHWAY_API_URL=http://pathway-reports-api:8000

# Trading Agents API Port (default: 8001)
API_PORT=8001

# ============================================
# Database Configuration
# ============================================

# PostgreSQL - stores agent reports and trade signals
DATABASE_URL=postgresql://user:password@host:5432/trading_db

# MongoDB - for LangGraph state checkpointing
MONGODB_URI=mongodb://user:password@host:27017/trading_agents

# ============================================
# Redis Queue Configuration (Upstash TCP)
# ============================================

# Get this from your Upstash Redis dashboard:
# 1. Go to your Redis database
# 2. Click on "TCP" tab (not REST)
# 3. Copy the REDIS_URL value
# Format: redis://default:TOKEN@hip-narwhal-28839.upstash.io:6379
# Or for TLS: rediss://default:TOKEN@hip-narwhal-28839.upstash.io:6379
REDIS_URL=redis://default:********@hip-narwhal-28839.upstash.io:6379

# ============================================
# LLM Configuration
# ============================================

# OpenAI API Key (required for all agents)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Workflow Configuration
# ============================================

# Default stock symbol (for standalone runs)
STOCK_SYMBOL=AAPL

# Use sample/fallback data if input reports unavailable
USE_FALLBACK_DATA=false

# Maximum debate rounds between bull and bear
MAX_DEBATE_ROUNDS=1

# Maximum risk discussion rounds
MAX_RISK_DISCUSS_ROUNDS=1

# ============================================
# Docker/Networking (for docker-compose)
# ============================================

# Internal service name for Pathway API
# PATHWAY_API_URL=http://pathway-reports-api:8000

# Internal service hostname
# TRADING_AGENTS_HOST=trading-agents-api

