# OpenAI Configuration
OPENAI_API_KEY=same_open_router_key
OPENAI_MODEL=gpt-4o-mini

# Financial Modeling Prep API Configuration
# Get your free API key at: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=api
CRUNCHBASE_API_KEY=api
COMPANY_NAMES=amazon
OPENROUTER_API_KEY="same_open_router_key"
OPENAI_API_KEY="same_open_router_key"
OPENAI_API_BASE="https://openrouter.ai/api/v1"
OPENAI_EMBED_MODEL="text-embedding-3-small"
VISION_AGENT_API_KEY=landingai
LANDINGAI_API_KEY=same_as_above_just_in_case
SERPEX_API_KEY=serpex

RAG_API_URL=http://localhost:8000
KNOWLEDGE_BASE_PATH=/app/knowledge_base

DEMO_TICKER=AAPL
DEMO_INTERVAL=5m
DEMO_SPEEDUP=10.0

MARKET_LOOKBACK_MINUTES=10
MARKET_HOP_MINUTES=5
MIN_DATA_POINTS=30

PATHWAY_SNAPSHOT_INTERVAL_MS=60000
PATHWAY_STATE_DIR=./pathway_state

SIMILARITY_THRESHOLD=0.75
MERGE_THRESHOLD=0.85
MAX_POSTS_PER_CLUSTER=50
CLUSTER_MAX_AGE_HOURS=48

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0


STOCKS=AAPL,GOOGL,MSFT,TSLA,NVDA

# Stock symbol → Company name JSON map
STOCK_COMPANY_MAP={"AAPL":"Apple Inc.","GOOGL":"Alphabet Inc.","MSFT":"Microsoft Corporation","TSLA":"Tesla Inc.","NVDA":"NVIDIA Corporation"}


# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_BROKER=localhost:9023

# ============================================
# BACKTESTING PIPELINE CONFIGURATION
# ============================================
CANDLE_KAFKA_TOPIC=candles
STRATEGIES_DIR=./strategies
CONSUMER_GROUP=pathway-backtester
API_URL=

# ============================================
# SENTIMENT ALERTS CONFIGURATION
# ============================================
SENTIMENT_ALERT_ENABLED=true
SENTIMENT_ALERT_MIN=-0.15
SENTIMENT_ALERT_MAX=0.15
SENTIMENT_ALERT_COOLDOWN=600
BULLBEAR_API_URL=http://unified-api:8000

BULLBEAR_GUARDRAILS_ENABLED=true
PATHWAY_LICENSE_KEY=key
# ============================================
# ORCHESTRATOR / MCP SERVER CONFIGURATION
# ============================================
# MCP Server settings
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=9004

# Risk assessment LLM model (lightweight model for quick decisions)
OPENAI_MODEL_RISK=google/gemini-2.0-flash-lite-001
OPENAI_TEMPERATURE_RISK=0.0
OPENAI_MAX_TOKENS_RISK=500

# Agent LLM model (more capable model for reasoning)
OPENAI_MODEL_AGENT=openai/gpt-4o-mini

# SerpAPI for web search (get key at https://serpapi.com)
SERPAPI_API_KEY=your_serpapi_key

# Backtesting API URL (internal Docker network)
BACKTESTING_API_URL=http://unified-api:8000/backtesting
REPORTS_API_URL=http://unified-api:8000

# ============================================
# MEM0 MEMORY CONFIGURATION
# ============================================
# Uses existing Redis for vector storage
MEM0_REDIS_HOST=redis
MEM0_REDIS_PORT=6379

# Sentiment Report generation interval (seconds) - how often Phase 2 generates reports per symbol
REPORT_GENERATION_INTERVAL=300

UNSTRUCTURED_API_KEY=your_key_here