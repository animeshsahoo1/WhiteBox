# OpenAI Configuration
OPENAI_API_KEY=same_open_router_key
OPENAI_MODEL=gpt-4o-mini

# Financial Modeling Prep API Configuration
# Get your free API key at: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=api
CRUNCHBASE_API_KEY=api
COMPANY_NAMES=amazon
OPENROUTER_API_KEY="same_open_router_key"
OPENAI_API_KEY="same_open_router_key"
OPENAI_API_BASE="https://openrouter.ai/api/v1"
OPENAI_EMBED_MODEL="text-embedding-3-small"
VISION_AGENT_API_KEY=landingai
SERPEX_API_KEY=serpex

RAG_API_URL=http://localhost:8000
KNOWLEDGE_BASE_PATH=/app/knowledge_base

DEMO_TICKER=AAPL
DEMO_INTERVAL=5m
DEMO_SPEEDUP=10.0

MARKET_LOOKBACK_MINUTES=10
MARKET_HOP_MINUTES=5
MIN_DATA_POINTS=30

PATHWAY_SNAPSHOT_INTERVAL_MS=60000
SENTIMENT_CLUSTER_STATE_DIR=./sentiment_cluster_state

SIMILARITY_THRESHOLD=0.75
MERGE_THRESHOLD=0.85
MAX_POSTS_PER_CLUSTER=50
CLUSTER_MAX_AGE_HOURS=48

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0


STOCKS=AAPL,GOOGL,MSFT,TSLA,NVDA

# Stock symbol → Company name JSON map
STOCK_COMPANY_MAP={"AAPL":"Apple Inc.","GOOGL":"Alphabet Inc.","MSFT":"Microsoft Corporation","TSLA":"Tesla Inc.","NVDA":"NVIDIA Corporation"}


# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_BROKER=localhost:9023

SENTIMENT_ALERT_ENABLED=true
SENTIMENT_ALERT_MIN=-0.15
SENTIMENT_ALERT_MAX=0.15
SENTIMENT_ALERT_COOLDOWN=600
BULLBEAR_API_URL=http://reports-api:8000

# Sentiment Report generation interval (seconds) - how often Phase 2 generates reports per symbol
REPORT_GENERATION_INTERVAL=300
