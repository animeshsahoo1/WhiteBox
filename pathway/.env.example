# ============================================
# OPENAI / OPENROUTER CONFIGURATION
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (used for embeddings + LLM)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Alternative model override
# OPENAI_MODEL=openai/gpt-4o-mini


# ============================================
# AGENTIC RAG CONFIGURATION
# ============================================
RAG_API_URL=http://localhost:7001
KNOWLEDGE_BASE_PATH=/app/knowledge_base

# Serpex Search API (for web search)
SERPEX_API_KEY=your-serpex-api-key-here


# ============================================
# STOCKS CONFIGURATION
# ============================================
# Tracking list
STOCKS=AAPL,GOOGL,MSFT,TSLA,NVDA

# Stock symbol → Company name JSON map
STOCK_COMPANY_MAP={"AAPL":"Apple Inc.","GOOGL":"Alphabet Inc.","MSFT":"Microsoft Corporation","TSLA":"Tesla Inc.","NVDA":"NVIDIA Corporation"}


# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_BROKER=localhost:9023
# For docker-based deployment
# KAFKA_BROKER=kafka:9023


# ============================================
# REDIS CONFIGURATION (for caching/pubsub)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# For docker-compose deployment
# REDIS_HOST=redis

# Optional TTL for cached reports
# REDIS_REPORT_TTL=86400
# Alternative:
# REDIS_URL=redis://localhost:6379/0


# ============================================
# SENTIMENT AGENT CONFIGURATION
# ============================================
SIMILARITY_THRESHOLD=0.75
MERGE_THRESHOLD=0.85
MAX_POSTS_PER_CLUSTER=50
CLUSTER_MAX_AGE_HOURS=48


# ============================================
# PATHWAY PERSISTENCE CONFIGURATION
# ============================================
PATHWAY_SNAPSHOT_INTERVAL_MS=60000
SENTIMENT_CLUSTER_STATE_DIR=./sentiment_cluster_state


# ============================================
# DEMO MARKET SERVICE CONFIGURATION
# ============================================
DEMO_TICKER=AAPL
DEMO_INTERVAL=5m
DEMO_SPEEDUP=10.0

MARKET_LOOKBACK_MINUTES=10
MARKET_HOP_MINUTES=5
MIN_DATA_POINTS=30

# Example configs:
# Fast:
# DEMO_SPEEDUP=100.0
# Detailed:
# DEMO_INTERVAL=1h
# DEMO_SPEEDUP=1.0
