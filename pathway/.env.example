# OpenAI Configuration
OPENAI_API_KEY=ur-key-here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter Configuration (for Agentic RAG)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Serpex API (for Web Search in Agentic RAG)
SERPEX_API_KEY=your-serpex-api-key-here

# RAG API Configuration
RAG_API_URL=http://localhost:7001
KNOWLEDGE_BASE_PATH=/app/knowledge_base

# Kafka Configuration
KAFKA_BROKER=localhost:9092

# Stock Symbol Mapping (JSON format)
STOCK_COMPANY_MAP={"AAPL":"Apple Inc.","MSFT":"Microsoft Corporation"}

# Redis Configuration (Optional - defaults to localhost:6379)
# REDIS_URL=redis://localhost:6379/0
# Or configure individually:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_REPORT_TTL=86400  # Optional: TTL in seconds for reports (default: no expiration)
