# ============================================
# PATHWAY SERVICE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values

# --------------------------------------------
# OPENAI / OPENROUTER API CONFIGURATION
# --------------------------------------------
# OpenRouter API Key (for embeddings and LLM calls)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alternative: Direct OpenAI API Key (fallback if OPENROUTER_API_KEY not set)
OPENAI_API_KEY=your_openai_api_key_here

# LLM Model to use (default: openai/gpt-4o-mini)
# Options: openai/gpt-4o-mini, openai/gpt-4o, openai/gpt-4-turbo, etc.
OPENAI_MODEL=openai/gpt-4o-mini


# --------------------------------------------
# STOCK SYMBOLS CONFIGURATION
# --------------------------------------------
# Comma-separated list of stock symbols to track
STOCKS=AAPL,GOOGL,MSFT,TSLA,NVDA

# Stock symbol to company name mapping (JSON format)
# Used in reports to show full company names
STOCK_COMPANY_MAP={"AAPL": "Apple Inc.", "GOOGL": "Alphabet Inc.", "MSFT": "Microsoft Corporation", "TSLA": "Tesla Inc.", "NVDA": "NVIDIA Corporation"}


# --------------------------------------------
# REDIS CONFIGURATION
# --------------------------------------------
# Redis connection settings for caching and pub/sub
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Alternative: Redis URL (overrides host/port/db if set)
# REDIS_URL=redis://redis:6379/0

# Redis report TTL in seconds (optional, default: no expiration)
# REDIS_REPORT_TTL=3600


# --------------------------------------------
# KAFKA CONFIGURATION
# --------------------------------------------
# Kafka broker address
KAFKA_BROKER=kafka:9092


# --------------------------------------------
# SENTIMENT AGENT CONFIGURATION
# --------------------------------------------
# Clustering similarity threshold (0.0 to 1.0)
# SIMILARITY_THRESHOLD=0.75

# Cluster merge threshold (0.0 to 1.0)
# MERGE_THRESHOLD=0.85

# Maximum posts per cluster (sliding window)
# MAX_POSTS_PER_CLUSTER=50

# Cluster expiration time in hours
# CLUSTER_MAX_AGE_HOURS=48


# --------------------------------------------
# PATHWAY PERSISTENCE CONFIGURATION
# --------------------------------------------
# Snapshot interval in milliseconds (default: 60000 = 1 minute)
# PATHWAY_SNAPSHOT_INTERVAL_MS=60000

# Persistence directory for cluster state
# SENTIMENT_CLUSTER_STATE_DIR=./sentiment_cluster_state


# --------------------------------------------
# VISUALIZATION SERVER CONFIGURATION
# --------------------------------------------
# Flask server port for visualization dashboard
# VISUALIZATION_PORT=5000

# Visualization data update interval in seconds
# VISUALIZATION_UPDATE_INTERVAL=10


# ============================================
# NOTES
# ============================================
# 1. For sentiment clustering, you MUST set either OPENROUTER_API_KEY or OPENAI_API_KEY
# 2. STOCK_COMPANY_MAP should be valid JSON with stock symbols as keys
# 3. Redis is required for caching and inter-service communication
# 4. Kafka is required for consuming streaming data from producers
# 5. All clustering parameters have sensible defaults and are optional
# Demo Market Service Configuration
# Copy these to your .env file or create .env.demo

# ====================================================================
# DEMO SERVICE SETTINGS (for market-demo service)
# ====================================================================

# Stock ticker to analyze
DEMO_TICKER=AAPL

# Data interval (1m, 5m, 10m, 15m, 30m, 1h)
# Must match available CSV files in demo_data/
DEMO_INTERVAL=5m

# Replay speed multiplier
# 1.0 = real-time, 10.0 = 10x faster, 100.0 = very fast
DEMO_SPEEDUP=10.0

# Analysis window configuration
MARKET_LOOKBACK_MINUTES=10  # How far back to analyze
MARKET_HOP_MINUTES=5        # How often to generate reports
MIN_DATA_POINTS=30          # Minimum data points per window

# ====================================================================
# API KEYS (Required for agent analysis)
# ====================================================================

# Option 1: OpenRouter (recommended for multiple models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Option 2: OpenAI (direct)
OPENAI_API_KEY=your_openai_api_key_here

# ====================================================================
# EXAMPLES FOR DIFFERENT SCENARIOS
# ====================================================================

# Quick Testing (very fast)
# DEMO_TICKER=AAPL
# DEMO_INTERVAL=1m
# DEMO_SPEEDUP=100.0
# MARKET_LOOKBACK_MINUTES=5
# MARKET_HOP_MINUTES=1
# MIN_DATA_POINTS=5

# Balanced (recommended)
# DEMO_TICKER=AAPL
# DEMO_INTERVAL=5m
# DEMO_SPEEDUP=10.0
# MARKET_LOOKBACK_MINUTES=10
# MARKET_HOP_MINUTES=5
# MIN_DATA_POINTS=30

# Detailed Analysis (slow, realistic)
# DEMO_TICKER=GOOGL
# DEMO_INTERVAL=1h
# DEMO_SPEEDUP=1.0
# MARKET_LOOKBACK_MINUTES=120
# MARKET_HOP_MINUTES=60
# MIN_DATA_POINTS=20
