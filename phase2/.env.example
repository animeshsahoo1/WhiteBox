# ============================================================================
# Phase 2 Environment Variables
# ============================================================================
# 
# This file documents the required environment variables.
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env with real credentials to version control.
#
# All other configuration is now in config.py
# ============================================================================

# ----------------------------------------------------------------------------
# Required: OpenAI API Configuration
# ----------------------------------------------------------------------------
# Your OpenAI API key for OpenRouter
OPENAI_API_KEY=your-openai-api-key-here

# ----------------------------------------------------------------------------
# Required: Pathway License
# ----------------------------------------------------------------------------
# Your Pathway license key
PATHWAY_LICENSE_KEY=your-pathway-license-key-here
