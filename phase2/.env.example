# ============================================================================
# Phase 2 Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# OpenAI Configuration
# ----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.operout.com/v1
OPENAI_MODEL_HYPOTHESIS=gpt-4o-mini
OPENAI_MODEL_RISK=gpt-4o-mini
OPENAI_MODEL_ORCHESTRATOR=gpt-4o-mini

# ----------------------------------------------------------------------------
# Trading Configuration
# ----------------------------------------------------------------------------
SYMBOL=AAPL
PATHWAY_LICENSE_KEY=your-pathway-license-key-here

# ----------------------------------------------------------------------------
# Redis Configuration (Hypothesis Caching)
# ----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ----------------------------------------------------------------------------
# PostgreSQL Configuration (Conversation Memory)
# ----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trading_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ----------------------------------------------------------------------------
# Pathway API Configuration (Phase 1 Reports)
# ----------------------------------------------------------------------------
PATHWAY_API_HOST=localhost
PATHWAY_API_PORT=9000

# ----------------------------------------------------------------------------
# Hypothesis Generator Configuration
# ----------------------------------------------------------------------------
HYPOTHESIS_API_HOST=0.0.0.0
HYPOTHESIS_API_PORT=8002
MCP_HOST=0.0.0.0
MCP_PORT=9000

# ----------------------------------------------------------------------------
# Risk Manager Configuration
# ----------------------------------------------------------------------------
RISK_MANAGER_HOST=0.0.0.0
RISK_MANAGER_PORT=9001
REPORTS_API_URL=http://pathway-api:8000

# ----------------------------------------------------------------------------
# Backtesting Configuration
# ----------------------------------------------------------------------------
BACKTESTING_SERVER_HOST=0.0.0.0
BACKTESTING_SERVER_PORT=8001
BACKTESTING_API_URL=http://backtesting-api:8001

# ----------------------------------------------------------------------------
# Orchestrator Configuration
# ----------------------------------------------------------------------------
STRATEGY_API_ENDPOINT=http://backtesting-api:8001/strategy-operations
RISK_ANALYSIS_MCP_URL=http://risk-managers:9001/mcp/
HYPOTHESIS_MCP_URL=http://hypothesis-generator:9000/mcp/

# Orchestrator LLM Settings
ORCH_LLM_TEMPERATURE=0.7
ORCH_LLM_MAX_TOKENS=4096

# Orchestrator Search Settings
ORCH_TIME_WINDOW=30d
ORCH_STRATEGY_LIMIT=5
ORCH_MAX_WEB_SEARCHES=2
ORCH_MAX_SYNTHESIS_ITERATIONS=5

# Orchestrator Performance Thresholds
ORCH_MIN_WIN_RATE=0.60
ORCH_MIN_SHARPE=1.5
ORCH_MIN_TRADE_COUNT=10

# Orchestrator API Timeouts
STRATEGY_API_SEARCH_TIMEOUT=20
STRATEGY_API_BACKTEST_TIMEOUT=30
WEB_SEARCH_RESULT_LENGTH=1000
